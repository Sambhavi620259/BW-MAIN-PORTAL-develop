# Backend origin (scheme + host + port), no path, no trailing slash.
# Canonical key — all API calls resolve to `{VITE_API_URL}/api/v1.0/...`.
VITE_API_URL=http://43.205.116.38:8080

# Optional legacy alias (same as VITE_API_URL if you already use this name).
# VITE_API_BASE_URL=http://43.205.116.38:8080

# DEV-only: use same-origin `/api/...` + Vite proxy instead of direct backend (default: false).
# VITE_USE_VITE_PROXY=true

# DEV-only: log full JWT + exact Authorization on GET /profile and compare verify-otp vs localStorage (never enable in shared builds).
# VITE_DEBUG_AUTH_TOKEN=true

# DEV-only: verbose GET /profile request/response (large logs).
# VITE_DEBUG_PROFILE=true

# When true, Admin Apps UI uses in-memory placeholders only (no /admin/apps HTTP). Default: live APIs.
# VITE_ADMIN_APPS_DEMO_ONLY=true

# When true, logs dashboard recent-apps / usage API responses to the console (can be noisy).
# VITE_DEBUG_DASHBOARD=true
